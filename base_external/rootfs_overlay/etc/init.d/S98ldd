#!/bin/sh

case "$1" in
  start)
    echo "S98lddmodules: loading LDD modules"

    # i) Load scull (uses scull_load script)
    if [ -x /usr/bin/scull_load ]; then
      /usr/bin/scull_load
    else
      echo "ERROR: /usr/bin/scull_load not found"
    fi

    # ii) Load faulty (uses module_load script)
    # module_load expects the module name (and loads /lib/modules/<name>.ko)
    if [ -x /usr/bin/module_load ]; then
      /usr/bin/module_load faulty
    else
      echo "ERROR: /usr/bin/module_load not found"
    fi

    # iii) Load hello using modprobe
    # This requires hello.ko to be in a modprobe-searchable path OR MODULES.dep exists.
    # We'll try modprobe first; if it fails, fall back to insmod.
    if command -v modprobe >/dev/null 2>&1; then
      modprobe hello 2>/dev/null || {
        echo "WARNING: modprobe hello failed, trying insmod /lib/modules/hello.ko"
        insmod /lib/modules/hello.ko 2>/dev/null || true
      }
    else
      echo "WARNING: modprobe not available, trying insmod /lib/modules/hello.ko"
      insmod /lib/modules/hello.ko 2>/dev/null || true
    fi
    ;;

  stop)
    echo "S98lddmodules: unloading LDD modules"

    # iii) Remove hello via rmmod
    rmmod hello 2>/dev/null || true

    # ii) Unload faulty via module_unload (expects module name)
    if [ -x /usr/bin/module_unload ]; then
      /usr/bin/module_unload faulty || true
    else
      rmmod faulty 2>/dev/null || true
    fi

    # i) Unload scull via scull_unload script
    if [ -x /usr/bin/scull_unload ]; then
      /usr/bin/scull_unload || true
    else
      rmmod scull 2>/dev/null || true
    fi
    ;;

  restart)
    $0 stop
    $0 start
    ;;

  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac

exit 0